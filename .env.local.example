# GensanWorks Admin Portal - Environment Configuration
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=5000

# Database Configuration
# For local development with SQLite:
# DATABASE_URL=file:./app.db

# For Supabase Postgres (recommended for hosting):
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require

# Supabase (Auth + Storage)
# Required to enable Supabase Auth-backed login/signup + JWT verification.
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>

# Required for server-side uploads to Supabase Storage (keep secret; server-only)
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# Bucket name used by /api/upload/employer-docs (create this in Supabase Storage)
# Make it PUBLIC if you want direct public URLs.
SUPABASE_STORAGE_BUCKET=gensanworks-uploads

# JWT Configuration
# Legacy JWT (kept for backwards compatibility). When Supabase vars are set, the server will prefer Supabase auth.
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=10

# Default Admin Credentials (set during seeding):
# Email: admin@gensanworks.com
# Password: AdminPassword123!

# Optional: SMTP Configuration for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
